# Copy to predictor/.env and fill in. NEVER commit the real .env.
# The wallet + API creds you already shared are burned — rotate before using.

POLY_CLOB_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137

# EOA private key that signs orders (0x-prefixed, 64 hex chars)
POLY_PRIVATE_KEY=0xREPLACE_ME

# Wallet address that holds the USDC and CTF shares
POLY_FUNDER_ADDRESS=0xREPLACE_ME

# 0 = EOA direct (default), 1 = magic/email proxy, 2 = browser proxy
POLY_SIGNATURE_TYPE=0

# CLOB L2 credentials (created once via /auth/api-key)
POLY_API_KEY=REPLACE_ME
POLY_API_SECRET=REPLACE_ME
POLY_API_PASSPHRASE=REPLACE_ME

# Strategy knobs
BOT_STAKE_USDC=1.0
BOT_HIGH_CONF=7.0
BOT_MAX_SLIPPAGE_BPS=200
BOT_DRY_RUN=true

# Drift-noise gate — skip when |drift_pct| < threshold AND conf >= floor.
# Catches "high-conf trade in dead market" failure mode. 0 disables.
BOT_NOISE_DRIFT_PCT=0.0005
BOT_NOISE_CONF_FLOOR=10.0

# Mid-price-high-conf gate — at conf >= floor, skip if chosen ask < cap.
# Tightened 2026-05-15: floor raised 12 -> 20 because the gate was blocking
# 70% winners in the post-deploy window (+$0.81/$1 of blocked trades).
# 0 disables.
BOT_MID_PRICE_CAP=0.55
BOT_MID_PRICE_CONF_FLOOR=20.0

# Contra-book confidence ceiling — `contra_book` (ask<0.40) only fires at
# conf < ceiling. At conf>=7 the bot's signal beats the book's disagreement.
# Set to a large value (e.g. 100) for old always-fire behavior. 0 disables.
BOT_CONTRA_BOOK_MAX_CONF=7.0

# UP-direction confidence floor (independent of BOT_HIGH_CONF). Asymmetric:
# UP at conf<7 has per-$1 EV -$0.05 in the 53-trade post-gate window;
# DOWN at the same conf is profitable. Gate fires only on UP. 0 disables.
BOT_UP_HIGH_CONF=7.0

# High-entry + mid-conf gate — skip when chosen-side ask >= cap AND conf
# < floor. Both 2026-05-15 $70 losses fit (entry 0.72/0.77, conf 7.9/8.3).
# Set BOT_HIGH_ENTRY_CAP=0 to disable.
BOT_HIGH_ENTRY_CAP=0.70
BOT_HIGH_ENTRY_CONF_FLOOR=12.0

# Crowd-indecision flip confidence band — the `crowd_indecision_contra`
# flip rule (invert direction when crowd ~50/50 AND chosen-side ask <= 0.50)
# only fires when confidence is in [BOT_CROWD_FLIP_MIN_CONF, BOT_CROWD_FLIP_MAX_CONF).
# Historical edge concentrates entirely in conf [7, 12) — 8 of 9 flipped
# wins, +$0.62/$1 EV per firing. At conf <7 the signal beats the flip;
# at conf >=12 sample size is too small to decide. Outside the band the
# original signal proceeds untouched.
BOT_CROWD_FLIP_MIN_CONF=7.0
BOT_CROWD_FLIP_MAX_CONF=12.0

# Ask-recheck gate (T+8s adverse-move check). When enabled, the bot sleeps
# 8s after deciding, refetches the ask, and aborts if ask moved up by >tol
# (only when original ref ask was <= MAX_REF_ASK). DISABLED by default
# after the 2026-05-15 audit found it blocked 26 trades of which 22 (85%)
# would have won — even at realistic post-jump fill prices the gate cost
# ~$0.19/$1 forgone per blocked trade. In a binary up/down market, ask
# jumping up after a BUY usually confirms the prediction, not refutes it.
# The 2% MAX_SLIPPAGE_BPS at the FOK order layer already protects against
# truly bad fills. Re-enable with BOT_ASK_RECHECK_ENABLED=true.
BOT_ASK_RECHECK_ENABLED=false
BOT_ASK_RECHECK_DELAY_S=8.0
BOT_ASK_RECHECK_TOLERANCE=0.05
BOT_ASK_RECHECK_TIMEOUT_S=3.0
BOT_ASK_RECHECK_MAX_REF_ASK=0.70

# Pre-trade reconciliation. At bot startup (before the predictor loop runs),
# query Polymarket's positions API for any orphan winning positions — shares
# from past trades that the bot owns on-chain but never recorded in
# trade_history.jsonl. Typical cause: process crash between the BUY order
# fill and the JSONL write, leaving the auto-redeem path unaware. Without
# this sweep, winning shares can sit unclaimed indefinitely. Recovered
# $56.73 on the initial 2026-05-18 deployment. Idempotent — safe to keep
# on across restarts. Set to false to skip the API call at startup.
BOT_RECONCILE_ON_START=true

# LSTM-inverted alignment gate. The bot's blend treats LSTM as anti-predictive
# (inverted weight). When the final chosen direction *agrees* with LSTM's
# raw call, that's the losing bucket — OOS conditional backtest n=58, 52% W,
# E[$1]=-$0.090. When it disagrees, n=102, 74.5% W, E[$1]=+$0.245 (boot CI
# [+$0.100, +$0.392], does not cross zero). This gate skips the lose bucket.
# The strongest surviving conditional edge after IS→OOS decay validation.
# Set to false to disable.
BOT_LSTM_INV_GATE=true

# Hour-of-day blackout (local time, matches trade_history.jsonl timestamps).
# Comma-separated half-open ranges; skip any prediction whose local hour falls
# inside one of them. OOS quant backtest hour buckets:
#   [00,06): n=57 E[$1]=+$0.096
#   [06,12): n=27 E[$1]=+$0.210
#   [12,18): n=43 E[$1]=+$0.217
#   [18,24): n=33 E[$1]=-$0.020  <-- only losing slot
# Format: "18-24" or "0-6,18-24". Empty string disables.
BOT_BLACKOUT_HOURS=18-24
